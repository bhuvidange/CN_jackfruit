<routes>

<vType id="car" accel="1.0" decel="4.5" sigma="0.5" length="5"/>    <!-- Define vehicle type with specific parameters -->
<!-- sigma is the standard deviation of the driver's imperfection -->

<route id="north_south" edges="north_in south_out"/>    <!-- Define route from north to south -->
<route id="south_north" edges="south_in north_out"/>    <!-- Define route from south to north -->
<route id="east_west" edges="east_in west_out"/>    <!-- Define route from east to west -->
<route id="west_east" edges="west_in east_out"/>    <!-- Define route from west to east -->

<!-- HIGH TRAFFIC -->
<flow id="f1" route="north_south" begin="0" end="100" probability="0.35"/>
<flow id="f2" route="south_north" begin="0" end="100" probability="0.35"/>
<flow id="f3" route="east_west" begin="0" end="100" probability="0.35"/>
<flow id="f4" route="west_east" begin="0" end="100" probability="0.35"/>

<!-- LOW TRAFFIC -->
<flow id="f5" route="north_south" begin="100" end="200" probability="0.05"/>
<flow id="f6" route="south_north" begin="100" end="200" probability="0.05"/>
<flow id="f7" route="east_west" begin="100" end="200" probability="0.05"/>
<flow id="f8" route="west_east" begin="100" end="200" probability="0.05"/>

<!-- MEDIUM TRAFFIC -->
<flow id="f9" route="north_south" begin="200" end="300" probability="0.15"/>
<flow id="f10" route="south_north" begin="200" end="300" probability="0.15"/>
<flow id="f11" route="east_west" begin="200" end="300" probability="0.15"/>
<flow id="f12" route="west_east" begin="200" end="300" probability="0.15"/>

</routes>